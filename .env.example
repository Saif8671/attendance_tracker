# Twilio SMS Configuration (required for SMS alerts)
# Sign up at https://www.twilio.com to get these credentials
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE=+1234567890   # Your Twilio phone number

# QR Code Settings
QR_VALID_SECONDS=120         # How long each QR is valid (seconds)

# Attendance Alert Threshold
SMS_THRESHOLD=75             # Send SMS if attendance drops below this %

# Flask Secret Key (change this in production!)
FLASK_SECRET=change_me_in_production
